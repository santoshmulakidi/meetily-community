# Meetily Community+ Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_PASSWORD=meetily_secure_password_CHANGE_ME_IN_PRODUCTION

# =============================================================================
# Server Configuration
# =============================================================================
RUST_LOG=info
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# =============================================================================
# API Keys - Set these from your provider dashboards
# =============================================================================

# NVIDIA API (recommended - free tier available)
# Get from: https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=

# OpenAI API (optional)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter API (optional - access to 8+ models)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama (optional - for local LLMs)
OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# Provider Configuration
# =============================================================================

# Transcription provider: nvidia, whisper, faster-whisper
TRANSCRIPTION_PROVIDER=nvidia
TRANSCRIPTION_MODEL=parakeet-0.6b

# Summary provider: openrouter, ollama, nvidia, openai
SUMMARY_PROVIDER=openrouter
SUMMARY_MODEL=meta-llama/llama-3.1-70b-instruct

# Embedding provider: nvidia, openai, local
EMBEDDING_PROVIDER=nvidia
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# =============================================================================
# Storage Configuration
# =============================================================================
STORAGE_PATH=/var/meetily/recordings

# =============================================================================
# Authentication (Phase 13)
# =============================================================================
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars

# =============================================================================
# Monitoring (Optional)
# =============================================================================
GRAFANA_PASSWORD=admin

# =============================================================================
# Docker Build Configuration
# =============================================================================
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1