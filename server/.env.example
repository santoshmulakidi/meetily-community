# Meetily Community+ Server Configuration
# Copy this to .env and update with your values

# ============================================
# Server Configuration
# ============================================
MEETELY__SERVER__HOST=0.0.0.0
MEETELY__SERVER__PORT=8080
MEETELY__SERVER__LOG_LEVEL=info

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Format: postgresql://username:password@host:port/database
MEETELY__DATABASE__URL=postgresql://meetily:meetily_password@localhost:5432/meetily
MEETELY__DATABASE__MAX_CONNECTIONS=10
MEETELY__DATABASE__MIN_CONNECTIONS=2

# ============================================
# Storage Configuration
# ============================================
MEETELY__STORAGE__RECORDINGS_PATH=/var/meetily/recordings
MEETELY__STORAGE__MAX_FILE_SIZE_MB=1024
MEETELY__STORAGE__RETENTION_DAYS=30

# ============================================
# Transcription Configuration
# ============================================
MEETELY__TRANSCRIPTION__DEFAULT_PROVIDER=whisper
MEETELY__TRANSCRIPTION__WHISPER_MODEL=large-v3

# NVIDIA API (free tier available)
MEETELY__TRANSCRIPTION__NVIDIA_API_KEY=  # Optional: Your NVIDIA API key
MEETELY__TRANSCRIPTION__NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ============================================
# Summary Provider Configuration
# ============================================
MEETELY__SUMMARY__DEFAULT_PROVIDER=ollama

# Ollama (local, free)
MEETELY__SUMMARY__OLLAMA_BASE_URL=http://localhost:11434
MEETELY__SUMMARY__OLLAMA_MODEL=llama3.1:8b

# OpenRouter (optional, many free models)
MEETELY__SUMMARY__OPENROUTER_API_KEY=  # Optional: Your OpenRouter API key
MEETELY__SUMMARY__OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ============================================
# Authentication Configuration
# ============================================
MEETELY__AUTH__JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
MEETELY__AUTH__TOKEN_EXPIRY_HOURS=24
MEETELY__AUTH__REFRESH_TOKEN_EXPIRY_DAYS=7

# ============================================
# Optional: Embedding Model Configuration
# ============================================
# For RAG and semantic search
MEETELY__EMBEDDING__MODEL=sentence-transformers/all-MiniLM-L6-v2
MEETELY__EMBEDDING__DIMENSION=384